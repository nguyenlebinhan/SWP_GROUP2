<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" 
         xmlns="https://jakarta.ee/xml/ns/jakartaee" 
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">

    <!-- =====================================================================
         SERVICE INITIALIZATION LISTENERS
         ===================================================================== -->
    
    <!-- System Automated Scheduler Listener -->
    <!-- Initializes the daily contract batch processor on application startup -->
    <listener>
        <listener-class>listener.ContractSchedulerInitializerListener</listener-class>
    </listener>

    <!-- =====================================================================
         FILTER REGISTRATIONS (Security Filters)
         ===================================================================== -->
    
    <!-- Contract Authorization Filter -->
    <!-- Protects administrative contract endpoints with dynamic RBAC -->
    <filter>
        <filter-name>ContractAuthorizationFilter</filter-name>
        <filter-class>controller.ContractAuthorizationFilter</filter-class>
        <init-param>
            <param-name>permissionCode</param-name>
            <param-value>PERM_APPROVE_CONTRACT</param-value>
        </init-param>
    </filter>

    <!-- =====================================================================
         SERVLET REGISTRATIONS (No Annotations - Pure web.xml)
         ===================================================================== -->
    
    <servlet>
        <servlet-name>AuthController</servlet-name>
        <servlet-class>controller.AuthController</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>SystemAdminController</servlet-name>
        <servlet-class>controller.SystemAdminController</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>ManagerController</servlet-name>
        <servlet-class>controller.ManagerController</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>EmployeeController</servlet-name>
        <servlet-class>controller.EmployeeController</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>BusinessAdminController</servlet-name>
        <servlet-class>controller.BusinessAdminController</servlet-class>
    </servlet>

    <!-- HR Manual Contract Activation Servlet -->
    <!-- Handles POST /contracts/activate for DRAFT -> ACTIVE/PENDING_ACTIVATION -->
    <servlet>
        <servlet-name>ContractActivationServlet</servlet-name>
        <servlet-class>controller.ContractActivationServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>

    <!-- Contract Approval Servlet (Phase 7) -->
    <!-- Handles POST /contracts/approve for PENDING_APPROVAL -> PENDING_ACTIVATION / CANCELLED -->
    <servlet>
        <servlet-name>ContractApprovalServlet</servlet-name>
        <servlet-class>controller.ContractApprovalServlet</servlet-class>
        <load-on-startup>3</load-on-startup>
    </servlet>

    <!-- Contract History Search Servlet (Phase 8) -->
    <!-- Handles GET /contracts/history for audit trail search -->
    <servlet>
        <servlet-name>ContractHistorySearchServlet</servlet-name>
        <servlet-class>controller.ContractHistorySearchServlet</servlet-class>
        <load-on-startup>4</load-on-startup>
    </servlet>

    <!-- =====================================================================
         SERVLET MAPPINGS
         ===================================================================== -->
    
    <servlet-mapping>
        <servlet-name>AuthController</servlet-name>
        <url-pattern>/v1/auth/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>SystemAdminController</servlet-name>
        <url-pattern>/v1/systemadmin/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>ManagerController</servlet-name>
        <url-pattern>/v1/manager/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>EmployeeController</servlet-name>
        <url-pattern>/v1/employee/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>BusinessAdminController</servlet-name>
        <url-pattern>/v1/businessadmin/*</url-pattern>
    </servlet-mapping>

    <!-- Contract Activation Endpoint (HR Manual Flow) -->
    <servlet-mapping>
        <servlet-name>ContractActivationServlet</servlet-name>
        <url-pattern>/contracts/activate</url-pattern>
    </servlet-mapping>

    <!-- Contract Approval Endpoint (Phase 7 - HR Manual Approval Flow) -->
    <servlet-mapping>
        <servlet-name>ContractHistorySearchServlet</servlet-name>
        <url-pattern>/contracts/history</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ContractApprovalServlet</servlet-name>
        <url-pattern>/contracts/approve</url-pattern>
    </servlet-mapping>

    <!-- Manager Contract Approval Views -->
    <servlet-mapping>
        <servlet-name>ContractApprovalServlet</servlet-name>
        <url-pattern>/v1/manager/contracts/pending</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ContractApprovalServlet</servlet-name>
        <url-pattern>/v1/manager/contracts/approve-preview</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ContractApprovalServlet</servlet-name>
        <url-pattern>/v1/manager/contracts/reject-dialog</url-pattern>
    </servlet-mapping>

    <!-- =====================================================================
         FILTER MAPPINGS
         ===================================================================== -->
    
    <!-- Protect contract approval endpoint with PERM_APPROVE_CONTRACT -->
    <filter-mapping>
        <filter-name>ContractAuthorizationFilter</filter-name>
        <url-pattern>/contracts/approve</url-pattern>
    </filter-mapping>

    <!-- Protect future administrative contract endpoints (e.g., /contracts/all) -->
    <filter-mapping>
        <filter-name>ContractAuthorizationFilter</filter-name>
        <url-pattern>/contracts/all</url-pattern>
    </filter-mapping>

</web-app>