<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <!-- ===== Filter chain (thứ tự chạy = thứ tự filter-mapping bên dưới) ===== -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>filter.CharacterEncodingFilter</filter-class>
    </filter>
    <filter>
        <filter-name>AuthorizationFilter</filter-name>
        <filter-class>filter.AuthorizationFilter</filter-class>
    </filter>
    <filter>
        <filter-name>AuditLogFilter</filter-name>
        <filter-class>filter.AuditLogFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/v1/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/v1/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuditLogFilter</filter-name>
        <url-pattern>/v1/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>AuthController</servlet-name>
        <servlet-class>controller.AuthController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SystemAdminController</servlet-name>
        <servlet-class>controller.SystemAdminController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthController</servlet-name>
        <url-pattern>/v1/auth/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SystemAdminController</servlet-name>
        <url-pattern>/v1/systemadmin/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ManagerController</servlet-name>
        <servlet-class>controller.ManagerController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ManagerController</servlet-name>
        <url-pattern>/v1/manager/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>EmployeeController</servlet-name>
        <servlet-class>controller.EmployeeController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EmployeeController</servlet-name>
        <url-pattern>/v1/employee/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>BusinessAdminController</servlet-name>
        <servlet-class>controller.BusinessAdminController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BusinessAdminController</servlet-name>
        <url-pattern>/v1/businessadmin/*</url-pattern>
    </servlet-mapping>

    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Block direct JSP access</web-resource-name>
            <url-pattern>*.jsp</url-pattern>
        </web-resource-collection>
        <auth-constraint/>
    </security-constraint>

</web-app>